# App
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/earth_tennis_club

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ISSUER=earth-tennis-club
JWT_AUDIENCE=earth-tennis-club-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Cookie
REFRESH_COOKIE_NAME=etc_refresh
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# Security
BCRYPT_COST=12
ARGON2_MEMORY_KB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
RATE_LIMIT_PER_MINUTE=120
